# copilot-workspace-setup — gitignore

# MCP Error Learning server — tracked in separate repo
mcp-error-learning/

# Context session logs — per-machine, should not be committed
.context/sessions/*.md

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/

# Node
node_modules/
.npm/

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
*.swp
*.swo

# Secrets
.env
.env.local
*.pem
*.key
